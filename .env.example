# === SEGURIDAD / JWT ===
# Genera un valor seguro con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_jwt_secret_here

# === SMTP (CORREO ELECTRÓNICO) ===
SMTP_USER=your_gmail@gmail.com
# Usa una contraseña de aplicación de Google, no tu contraseña normal
SMTP_PASSWORD=your_app_password_here

# === ADMINISTRADOR ===
# Hash bcrypt de la contraseña del admin (generado con pwd_context.hash())
ADMIN_PASSWORD=your_hashed_password_here

# === CONFIGURACIÓN TWILIO WHATSAPP ===
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_FROM=+14155552671
# Formato: +57XXXXXXXXXX (tu número en Colombia)

# === BASE DE DATOS ===
# DATABASE_URL=postgresql://user:password@localhost/dbname
# Si no está definido, usa SQLite por defecto

# === AUTOMATIZACION ===
# Horario para enviar recordatorios (formato HH:MM en 24 horas)
RECORDATORIO_HORA=08:00
RECORDATORIO_MINUTOS=00
